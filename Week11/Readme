//ts. TypeScript เขียนLogic +เช๊ค Type(ไม่วาดUI)
//tsx. เหมือกันเเต่ วาดUi ได้ ครบเครื่องเลยนะ

{/* 
    
const items : CartState = [];
เปรียบเทียบเหมือนคุณกำลังบอกคอมพิวเตอร์ว่า:
นิยาม (Type): "สิ่งนี้คือ ตะกร้าหนึ่งใบ (CartState)"
สิ่งที่ใส่เข้าไป (Value): "แต่ฉันจะส่ง รายการว่างเปล่า ( [ ] ) ไปให้นะ"

อธิบายต่อ ถ้าไม่ใส่ [] (เป็นชิ้นเดียว) : 
🦖const item: CartState = { id: 1, name: 'Apple' };
**1 เดี่ยว
-เปรียบเทียบ : เหมือนคุณเดินไปหยิบแอปเปิ้ล 1ลูก
-Type: คือ CartState (ส้ม 1 ผล, เสื้อ 1 ตัว)

🦖const items: CartState[] = [];
**หลายอย่างมากมาย
-เปรียบเทียบ: เหมือนคุณถือ "ตะกร้าเปล่า" ที่เตรียมเอาไว้ใส่แอปเปิลหลายๆ ลูก
-Type: คือ CartState[] (รายการของส้ม, รายการของเสื้อ)

*/}